# =====================================================================
# Variables d'environnement pour le deploiement RPi4
#
# Copier en .env (lu automatiquement par docker-compose) :
#   cp env.rpi.example .env
#
# Adapter selon ton reseau :
# =====================================================================

# --- Reseau ---
# IP du Summit XL (master ROS 1 Kinetic)
ROBOT_IP=192.168.0.200

# IP de la RPi4 sur le reseau du robot
RPI_IP=192.168.0.50

# Pour le bridge ROS1: ROS_MASTER_URI doit pointer vers le Summit
MY_IP=192.168.0.50

# Interface reseau utilisee pour DDS (eth0 = ethernet RJ45)
NETWORK_INTERFACE=eth0

# --- ROS 2 ---
ROS_DOMAIN_ID=0
RMW_IMPLEMENTATION=rmw_cyclonedds_cpp

# --- Step input (utile pour identification) ---
AXIS=linear
STEP_VALUE=0.15
